# Environment Configuration Example
# Copy this file to .env and replace with your actual configuration
# Do NOT commit the actual .env file to version control.

# Database Configuration (MySQL recommended)
# Format: mysql+pymysql://<user>:<password>@<host>/<database_name>
DATABASE_URL=mysql+pymysql://root:yourpassword@localhost/gradeup_lite

# Security
# Run `openssl rand -hex 32` to generate a secure secret key
SECRET_KEY=CHANGE-THIS-TO-A-LONG-RANDOM-SECRET-KEY
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
